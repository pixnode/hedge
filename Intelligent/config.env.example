# Intelligent Department Configuration Example
# Rename this to config.env and fill in your keys

OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Gate Thresholds
CONFIDENCE_THRESHOLD=0.55
CONVERGENCE_THRESHOLD=0.30
NEWS_SENTIMENT_THRESHOLD=-0.70

# Additional Configuration
GATE_SIGNAL_TTL_SEC=300
POOL_MEMORY_DB=pool_memory.db
RETRAIN_TRIGGER_WINDOWS=100
RETRAIN_MIN_PRECISION=0.60
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
NEWS_RSS_URL=https://cointelegraph.com/rss
NEWS_CACHE_TTL_SEC=600
LARGE_TRADE_THRESHOLD=50000

# Notification Settings
TELEGRAM_NOTIFY_RECORDS=True
TELEGRAM_NOTIFY_OUTCOMES=True
TELEGRAM_NOTIFY_RETRAIN=True
